# BEGIN MANAGED:WORKLOADHUB_PIN_V1
workloadhub.jrmsu-tc.cloud {
    encode gzip
    reverse_proxy workloadhub-blue:8080
}

api-email-workloadhub.jrmsu-tc.cloud {
    encode gzip

    @root path /
    handle @root {
        respond "WorkloadHub API is running" 200
    reverse_proxy api-email-workloadhub:4000
    }

    @health_alias path /api/health /api/v1/health
    handle @health_alias {
        uri replace /api/health /health
        uri replace /api/v1/health /health
        reverse_proxy api-workload-hub:3000
    }

    handle {
        reverse_proxy api-workload-hub:3000
    }
}
# END MANAGED:WORKLOADHUB_PIN_V1
