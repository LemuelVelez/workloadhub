bookhive.jrmsu-tc.cloud {
  tls {
    issuer acme {
      disable_tlsalpn_challenge
    }
  }
  encode gzip zstd
  reverse_proxy bookhive-web:8080
}

api-bookhive.jrmsu-tc.cloud {
  tls {
    issuer acme {
      disable_tlsalpn_challenge
    }
  }
  encode gzip zstd
  reverse_proxy bookhive-api:5000
}






















# BEGIN MANAGED:api-queuepass.jrmsu-tc.cloud
# END MANAGED:api-queuepass.jrmsu-tc.cloud


api-queuepass.jrmsu-tc.cloud {
    encode gzip
    @legacy_health path /api/health
    handle @legacy_health {
        rewrite * /health
        reverse_proxy queuepass-api-blue:5000
    }
    reverse_proxy queuepass-api-blue:5000
}

queuepass.jrmsu-tc.cloud {
    encode gzip zstd
    handle /api/* {
    reverse_proxy queuepass-client-web:80
    }
    handle /auth/* {
        rewrite * /api{uri}
        reverse_proxy queuepass-api-blue:5000
    }
    handle {
        reverse_proxy queuepass-client-web:80
    }
}



